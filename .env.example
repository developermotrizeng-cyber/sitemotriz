# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Conexão com o Supabase (Substitua pelos valores reais do seu painel Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-chave-anonima-publica"

# Senhas de acesso do painel de administração (separadas por vírgula se houver mais de uma)
ADMIN_PASSWORDS="senha"

# Configurações de SMTP do servidor de e-mail (seguro no servidor, não exposto ao cliente)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email-remetente@gmail.com"
SMTP_PASS="sua-senha-de-aplicativo"
SMTP_SECURE="false"
SMTP_TO="rh@motrizengenharia.com.br"
